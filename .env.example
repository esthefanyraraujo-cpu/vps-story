# NextAuth
NEXTAUTH_SECRET="gere-uma-chave-secreta-aleatoria-aqui"
NEXTAUTH_URL="http://localhost:3000"

# Hetzner Cloud API
HETZNER_API_TOKEN="seu-token-hetzner-aqui"

# Mercado Pago
MP_ACCESS_TOKEN="seu-access-token-mercadopago"
MP_WEBHOOK_SECRET="seu-webhook-secret-mercadopago"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# PagSeguro
